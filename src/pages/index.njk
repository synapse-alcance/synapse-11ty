<!-- Highlights -->
<section id="gallery" class="wrapper style1">
  <div class="title">Casos de sucesso</div>
  <div class="container">
    <div class="row aln-center">
      {% for case in gallery %}
      <div class="col-4 col-12-medium">
        <section class="case">
          <div class="review">
            <h3>{{ case.header }}</h3>
            <div class="review-card">
              <div class="review-card-header">
                <div class="review-card-avatar">
                  <img src="{{ site.path.prefix }}{{ site.path.assets }}{{ case.reviewerImg }}" alt="{{ case.reviewerAlt }}">
                  <span class="review-card-reviewer">
                    {{ case.reviewerName }}
                  </span>
                </div>
                <div class="review-card-rating">
                  <span class="review-card-rating-outer">
                    <span class="review-card-rating-inner"></span>
                  </span>
                </div>
              </div>
              <div class="review-card-quote">
                <div class="review-card-quote-decor">
                  “
                </div>
                <div class="review-card-quote-text">
                  {% for paragraph in case.reviewText %}
                  <p>{{ paragraph }}</p>
                  {% endfor %}
                </div>
              </div>
            </div>
          </div>
          <div class="case-description">
            {% for paragraph in case.text %}
            <p>{{ paragraph }}</p>
            {% endfor %}
          </div>
          <ul class="actions">
            <li><a href="{{ case.link }}" class="button style1">{{ case.btnText }}</a></li>
          </ul>
        </section>
      </div>
      {% endfor %}
    </div>
  </div>
</section>