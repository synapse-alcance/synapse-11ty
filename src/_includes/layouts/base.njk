<!DOCTYPE html>
<html lang="{{ site.meta.lang }}">
  
  <head>
    {% include "partials/sections/head.njk" %}
  </head>

  <body class="homepage is-preload">
    <div id="page-wrapper">

      <!-- Header -->
      <header id="header" class="wrapper" role="banner">
        {% include "partials/sections/header.njk" %}
      </header>

      <!-- Page content -->
      <main>
        {% block main %}
        {% endblock main %}
      </main>

      <!-- Footer -->
      <footer id="footer" class="wrapper">
        {% include "partials/sections/footer.njk" %}
      </footer>

    </div>

    <!-- Scripts -->
    <script src="{{ site.path.prefix }}{{ site.path.assets }}/js/jquery.min.js"></script>
    <script src="{{ site.path.prefix }}{{ site.path.assets }}/js/jquery.dropotron.min.js"></script>
    <script src="{{ site.path.prefix }}{{ site.path.assets }}/js/browser.min.js"></script>
    <script src="{{ site.path.prefix }}{{ site.path.assets }}/js/breakpoints.min.js"></script>
    <script src="{{ site.path.prefix }}{{ site.path.assets }}/js/util.js"></script>
    <script src="{{ site.path.prefix }}{{ site.path.assets }}/js/main.js"></script>

  </body>

</html>